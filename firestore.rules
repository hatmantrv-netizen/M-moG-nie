rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: flashcardSets
    // Document ID: setId (auto-generated)
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - grade: string (required)
    //   - subject: string (required)
    //   - topic: string (optional)
    //   - cards: list (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidFlashcardSet(data) {
      return data.keys().hasAll(['userId', 'title', 'grade', 'subject', 'cards']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.grade is string &&
             data.subject is string &&
             data.cards is list && data.cards.size() <= 50 &&
             (!('revisionSheet' in data) || (
               data.revisionSheet is map &&
               data.revisionSheet.lesson is string &&
               data.revisionSheet.keyPoints is list &&
               data.revisionSheet.keywords is list
             ));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /flashcardSets/{setId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidFlashcardSet(request.resource.data);
      allow update: if isDocOwner() && isValidFlashcardSet(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
